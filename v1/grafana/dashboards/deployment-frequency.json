    {
      "id": 5,
      "type": "timeseries",
      "title": "📈 Deployment Frequency Trend",
      "description": "DORA: Throughput · Weekly deployment count\nHigher is better — Elite teams deploy multiple times per day",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "DORA_PostgreSQL"
