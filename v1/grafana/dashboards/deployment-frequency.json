      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "DORA_PostgreSQL"
          },
          "rawSql": "SELECT\n  date_trunc('week', d.created_at) AS time,\n  COUNT(*) AS deployment_count\nFROM deployments d\nJOIN deployment_statuses ds ON ds.deployment_id = d.id\nWHERE d.environment = '$environment'\n  AND ds.state = 'success'\n  AND d.created_at BETWEEN $__timeFrom() AND $__timeTo()\n  AND ds.created_at = (SELECT MAX(created_at) FROM deployment_statuses WHERE deployment_id = d.id)\nGROUP BY 1\nORDER BY 1",
          "format": "time_series"
        }
      ],
