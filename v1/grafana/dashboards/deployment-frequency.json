      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "DORA_PostgreSQL"
          },
          "rawSql": "SELECT d.environment, LEFT(d.sha, 7) AS sha, d.created_at,\n  ds.state AS latest_status, u.login AS creator\nFROM deployments d\nLEFT JOIN LATERAL (SELECT state FROM deployment_statuses WHERE deployment_id = d.id ORDER BY created_at DESC LIMIT 1) ds ON true\nLEFT JOIN users u ON u.id = d.creator_user_id\nWHERE d.environment = '$environment'\n  AND d.created_at BETWEEN $__timeFrom() AND $__timeTo()\nORDER BY d.created_at DESC\nLIMIT 20",
          "format": "table"
        }
      ],
      "fieldConfig": {
