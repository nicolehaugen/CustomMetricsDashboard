    {
      "id": 3,
      "type": "stat",
      "title": "🚀 Deployment Frequency",
      "description": "DORA: Throughput · Average successful deployments per week\n\n🟢 Elite: >7/wk (daily)  ·  🟡 High: 1-7/wk  ·  🟠 Medium: <1/wk  ·  🔴 Low: <0.25/wk",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "DORA_PostgreSQL"
      },
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "DORA_PostgreSQL"
          },
          "rawSql": "SELECT\n  COUNT(*)::float / GREATEST(EXTRACT(EPOCH FROM ($__timeTo()::timestamp - $__timeFrom()::timestamp)) / 604800, 1) AS deploys_per_week\nFROM deployments d\nJOIN deployment_statuses ds ON ds.deployment_id = d.id\nWHERE d.environment = '$environment'\n  AND ds.state = 'success'\n  AND d.created_at BETWEEN $__timeFrom() AND $__timeTo()\n  AND ds.created_at = (SELECT MAX(created_at) FROM deployment_statuses WHERE deployment_id = d.id)",
          "format": "table"
        }
      ],
      "fieldConfig": {
