# GitHub Authentication (Classic PAT required)
# Scopes needed: repo, read:org, admin:org, actions, copilot
# Enterprise Copilot endpoints require Enterprise Owner role
GITHUB_TOKEN=ghp_your_token_here

# GitHub targets
GITHUB_ENTERPRISE=your-enterprise-slug   # for Copilot metrics endpoints
GITHUB_ORG=your-org                      # for DORA data + Copilot seats
GITHUB_REPO=your-repo                    # for DORA data

# PostgreSQL (matches docker-compose defaults)
PG_HOST=localhost
PG_DATABASE=metrics
PG_USER=postgres
PG_PASSWORD=postgres

# Sync server
PORT=3005
