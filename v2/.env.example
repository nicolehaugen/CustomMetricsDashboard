# GitHub
GITHUB_TOKEN=ghp_your_token_here
GITHUB_ORG=your-org-name
GITHUB_REPO=your-repo-name
GITHUB_ENTERPRISE=           # optional: enterprise slug for enterprise Copilot endpoints

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=dora_metrics
PG_USER=postgres
PG_PASSWORD=postgres

# Sync Server
PORT=3001

# Data Mode Banner
DATA_MODE=live               # live | seed
DATA_SOURCE_LABEL=your-org/your-repo
DATA_SOURCE_URL=https://github.com/your-org/your-repo
