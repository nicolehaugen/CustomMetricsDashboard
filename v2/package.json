{
  "name": "custom-metrics-dashboard",
  "version": "2.0.0",
  "description": "DORA + Copilot Impact Dashboard v2 — ELT architecture",
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint src/**/*.ts scripts/**/*.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "seed": "tsx scripts/seed.ts",
    "seed:verify": "tsx scripts/seed.ts --verify-only",
    "sync": "tsx scripts/sync.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@octokit/rest": "^20.0.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^10.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3"
  }
}
