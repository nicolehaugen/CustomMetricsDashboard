{
  "name": "custom-metrics-dashboard",
  "version": "1.0.0",
  "description": "DORA Metrics Dashboard — syncs GitHub data to PostgreSQL for Grafana visualization",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "seed": "tsx scripts/seed.ts",
    "seed:verify": "tsx scripts/seed.ts --verify-only",
    "sync": "tsx -e \"fetch('http://localhost:3001/api/sync',{method:'POST'}).then(r=>r.json()).then(console.log)\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test"
  },
  "dependencies": {
    "@octokit/rest": "^20.0.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@vitest/coverage-v8": "^4.1.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.3"
  }
}
